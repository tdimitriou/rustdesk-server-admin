# Install as /etc/rustdesk-server-admin.env with mode 600.
# Works with:
#   - systemd EnvironmentFile= (KEY=value lines only; no "export")
#   - scripts/rustdesk-server-admin.sh (uses set -a before sourcing)

ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=long-random-string

ADMIN_HOST=127.0.0.1
ADMIN_PORT=3030

HBBS_DB_PATH=/opt/rustdesk/db_v2.sqlite3

# Optional: public hbbs hostname for rustdesk://…/r@… links in the peer list
# RUSTDESK_CONNECT_RENDEZVOUS=rustdesk.example.com

# RUST_LOG=info
